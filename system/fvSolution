SIMPLE
{
   nNonOrthogonalCorrectors 2;
   residualControl
    {
        p               1e-2;
        U               1e-3;
    }
}


potentialFlow
{
    nNonOrthogonalCorrectors  10;
}

relaxationFactors
{
    fields
    {
        p               0.2;
    }
    equations
    {
        U               0.7;
    }
}

cache
{
    grad(U);
}

